# HamMediaLabs / Hydra Core — environment variables (template only).
# Copy to .env (which is gitignored) and fill values from the vault.

# --- AI providers ---
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://hammedialabs.example
OPENROUTER_TITLE=HamMediaLabs

# --- HQ data ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Heartbeat ---
HEARTBEAT_SOURCE=hq_cron

# --- Publish kill switch ---
HQ_PUBLISH_FREEZE=false
