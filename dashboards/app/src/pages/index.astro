---
import { listBrands, providerDaily, type BrandRow, type ProviderDailyRow } from '../lib/supabase.ts';

let brands: BrandRow[] = [];
let providers: ProviderDailyRow[] = [];
let connectError: string | null = null;
try {
  [brands, providers] = await Promise.all([listBrands(), providerDaily(14)]);
} catch (e) {
  connectError = (e as Error).message;
}

const totals = {
  brands_active: brands.filter(b => b.status === 'active').length,
  brands_hold:   brands.filter(b => b.status === 'hold').length,
  brands_kill:   brands.filter(b => b.status === 'kill').length,
  brands_scale:  brands.filter(b => b.status === 'scale').length,
  cost:    brands.reduce((s, b) => s + Number(b.monthly_cost_est || 0), 0),
  revenue: brands.reduce((s, b) => s + Number(b.monthly_revenue_est || 0), 0),
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>HamMediaLabs — HQ dashboard</title>
    <style>
      :root { font: 15px/1.5 system-ui, -apple-system, Segoe UI, sans-serif; }
      body { margin: 0; color: #1c1c1c; }
      main { max-width: 960px; margin: 0 auto; padding: 1.5rem; }
      h1 { margin: 0 0 1rem; }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem; }
      .card { border: 1px solid #ddd; border-radius: 6px; padding: 0.75rem 1rem; background: #fafafa; }
      .card .v { font-size: 1.5rem; font-weight: 600; }
      .card .k { color: #6a6a6a; font-size: 0.85rem; }
      table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
      th, td { text-align: left; padding: 0.4rem 0.6rem; border-bottom: 1px solid #eee; }
      th { background: #f6f6f6; }
      .err { background: #fdeded; color: #5f1d1d; border: 1px solid #f4b6b6; padding: 0.6rem 0.9rem; border-radius: 6px; }
      .pill { display: inline-block; padding: 0.1rem 0.5rem; border-radius: 999px; font-size: 0.8rem; }
      .pill.active { background: #d2f5d6; }
      .pill.hold   { background: #fff1c2; }
      .pill.kill   { background: #f7c5c0; }
      .pill.scale  { background: #c5d9f7; }
      .pill.planning { background: #e6e6e6; }
    </style>
  </head>
  <body>
    <main>
      <h1>HamMediaLabs — HQ dashboard</h1>

      {connectError && (
        <p class="err">
          Couldn't connect to Supabase: {connectError}.<br />
          Set <code>SUPABASE_URL</code> and <code>SUPABASE_SERVICE_ROLE_KEY</code> in the dev environment.
        </p>
      )}

      <section class="grid" aria-label="Portfolio totals">
        <div class="card"><div class="v">{totals.brands_active}</div><div class="k">Active</div></div>
        <div class="card"><div class="v">{totals.brands_hold}</div><div class="k">Hold</div></div>
        <div class="card"><div class="v">{totals.brands_scale}</div><div class="k">Scale</div></div>
        <div class="card"><div class="v">{totals.brands_kill}</div><div class="k">Killed</div></div>
        <div class="card"><div class="v">£{totals.cost.toFixed(0)}</div><div class="k">Monthly cost</div></div>
        <div class="card"><div class="v">£{totals.revenue.toFixed(0)}</div><div class="k">Monthly revenue</div></div>
      </section>

      <h2>Brands</h2>
      {brands.length === 0 ? (
        <p>No brands yet. Seed via <code>insert into brand …</code> or the upcoming admin UI.</p>
      ) : (
        <table>
          <thead><tr>
            <th>Slug</th><th>Name</th><th>Status</th><th>Tier</th><th>Cost/mo</th><th>Revenue/mo</th>
          </tr></thead>
          <tbody>
            {brands.map(b => (
              <tr>
                <td><code>{b.slug}</code></td>
                <td>{b.name}</td>
                <td><span class={`pill ${b.status}`}>{b.status}</span></td>
                <td>T{b.tier}</td>
                <td>£{Number(b.monthly_cost_est).toFixed(0)}</td>
                <td>£{Number(b.monthly_revenue_est).toFixed(0)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}

      <h2>Provider health (last 14 days)</h2>
      {providers.length === 0 ? (
        <p>No provider events yet. The LLM router writes here automatically once wired.</p>
      ) : (
        <table>
          <thead><tr>
            <th>Day</th><th>Provider</th><th>Calls</th><th>429s</th><th>Errors</th><th>Tokens in/out</th><th>Cost est ($)</th>
          </tr></thead>
          <tbody>
            {providers.map(p => (
              <tr>
                <td>{p.day.slice(0, 10)}</td>
                <td>{p.provider}</td>
                <td>{p.calls}</td>
                <td>{p.rate_limits}</td>
                <td>{p.errors}</td>
                <td>{p.tokens_in} / {p.tokens_out}</td>
                <td>{Number(p.cost_est).toFixed(4)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </main>
  </body>
</html>
