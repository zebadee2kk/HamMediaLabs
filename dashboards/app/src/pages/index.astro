---
import {
  envStatus,
  listBrands,
  listDecisions,
  providerDaily,
  type BrandRow,
  type DecisionRow,
  type ProviderDailyRow,
} from '../lib/supabase.ts';
import ConfigBanner from '../components/ConfigBanner.astro';
import ErrorPanel from '../components/ErrorPanel.astro';
import EmptyState from '../components/EmptyState.astro';
import PortfolioCards from '../components/PortfolioCards.astro';
import BrandTable from '../components/BrandTable.astro';
import ProviderHealthTable from '../components/ProviderHealthTable.astro';
import QuotaBurnIndicator from '../components/QuotaBurnIndicator.astro';
import DecisionsTable from '../components/DecisionsTable.astro';

const env = envStatus();

let brands: BrandRow[] = [];
let providers: ProviderDailyRow[] = [];
let decisions: DecisionRow[] = [];
let brandError: { status?: number; detail: string } | null = null;
let providerError: { status?: number; detail: string } | null = null;
let decisionError: { status?: number; detail: string } | null = null;

if (env.ok) {
  const [b, p, d] = await Promise.all([
    listBrands(),
    providerDaily(14),
    listDecisions(14),
  ]);
  if (b.ok) brands = b.data;
  else if (b.kind === 'fetch_error') brandError = { status: b.status, detail: b.detail };

  if (p.ok) providers = p.data;
  else if (p.kind === 'fetch_error') providerError = { status: p.status, detail: p.detail };

  if (d.ok) decisions = d.data;
  else if (d.kind === 'fetch_error') decisionError = { status: d.status, detail: d.detail };
}

const rendered = new Date().toISOString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>HamMediaLabs — HQ dashboard</title>
    <style>
      :root { font: 15px/1.5 system-ui, -apple-system, Segoe UI, sans-serif; }
      body { margin: 0; color: #1c1c1c; background: #fff; }
      main { max-width: 980px; margin: 0 auto; padding: 1.5rem; }
      header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1rem; }
      h1 { margin: 0; font-size: 1.4rem; }
      h2 { margin: 1.5rem 0 0.5rem; font-size: 1.1rem; }
      .stamp { color: #6a6a6a; font-size: 0.82rem; font-variant-numeric: tabular-nums; }
      nav.dash { margin: 0.5rem 0 1rem; font-size: 0.9rem; }
      nav.dash a { color: #114488; text-decoration: none; margin-right: 0.8rem; }
      nav.dash a:hover { text-decoration: underline; }
      .ops-note {
        margin: 1.5rem 0 0; padding-top: 0.75rem; border-top: 1px solid #eee;
        color: #6a6a6a; font-size: 0.85rem;
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <h1>HamMediaLabs — HQ dashboard</h1>
        <span class="stamp">rendered {rendered}</span>
      </header>
      <nav class="dash" aria-label="Dashboard sections">
        <a href="/">Overview</a>
        <a href="/cost">Cost</a>
        <a href="/decisions">Decisions</a>
        <a href="/experiments">Experiments</a>
      </nav>

      {!env.ok && <ConfigBanner missing={env.missing} />}

      <h2>Portfolio</h2>
      {env.ok && !brandError && brands.length === 0 && (
        <EmptyState
          message="No brands in the brand table yet."
          hint="seed via the playbooks/first-week.md Day 4 SQL block"
        />
      )}
      {brandError && (
        <ErrorPanel title="Couldn't load brands" status={brandError.status} detail={brandError.detail} />
      )}
      {brands.length > 0 && <PortfolioCards brands={brands} />}

      <h2>Brands</h2>
      {brands.length > 0
        ? <BrandTable brands={brands} />
        : env.ok && !brandError && <EmptyState message="Empty brand table." />}

      <h2>Free-tier quota headroom</h2>
      <QuotaBurnIndicator usage={[]} />

      <h2>Provider health (last 14 days)</h2>
      {providerError && (
        <ErrorPanel title="Couldn't load provider events" status={providerError.status} detail={providerError.detail} />
      )}
      {!providerError && providers.length === 0 && env.ok && (
        <EmptyState
          message="No provider events in the last 14 days."
          hint="the LLM router writes these automatically once wired"
        />
      )}
      {providers.length > 0 && <ProviderHealthTable rows={providers} />}

      <h2>Recent decisions (last 14 days)</h2>
      {decisionError && (
        <ErrorPanel title="Couldn't load decisions" status={decisionError.status} detail={decisionError.detail} />
      )}
      {!decisionError && decisions.length === 0 && env.ok && (
        <EmptyState
          message="No decisions in the last 14 days."
          hint="see full log at /decisions; entries land here automatically once wired"
        />
      )}
      {decisions.length > 0 && <DecisionsTable rows={decisions} />}

      <p class="ops-note">
        Read-only view. Service-role key is server-side only and never reaches
        the browser. This dashboard is statically rendered — to refresh data,
        trigger a rebuild. See <code>dashboards/app/README.md</code>.
      </p>
    </main>
  </body>
</html>
