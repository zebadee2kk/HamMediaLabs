---
import QuotaBurnIndicator from '../components/QuotaBurnIndicator.astro';
import CostBreakdownTable from '../components/CostBreakdownTable.astro';
import { envStatus } from '../lib/supabase.ts';
import ConfigBanner from '../components/ConfigBanner.astro';

const env = envStatus();
const rendered = new Date().toISOString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>HamMediaLabs — Cost & Profit</title>
    <style>
      :root { font: 15px/1.5 system-ui, -apple-system, Segoe UI, sans-serif; }
      body { margin: 0; color: #1c1c1c; background: #fff; }
      main { max-width: 980px; margin: 0 auto; padding: 1.5rem; }
      header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1rem; }
      h1 { margin: 0; font-size: 1.4rem; }
      h2 { margin: 1.5rem 0 0.5rem; font-size: 1.1rem; }
      .stamp { color: #6a6a6a; font-size: 0.82rem; font-variant-numeric: tabular-nums; }
      nav.dash { margin: 0.5rem 0 1rem; font-size: 0.9rem; }
      nav.dash a { color: #114488; text-decoration: none; margin-right: 0.8rem; }
      nav.dash a:hover { text-decoration: underline; }
      .ops-note { margin-top: 1.5rem; padding-top: 0.75rem; border-top: 1px solid #eee; color: #6a6a6a; font-size: 0.85rem; }
    </style>
  </head>
  <body>
    <main>
      <header>
        <h1>Cost &amp; Profit</h1>
        <span class="stamp">rendered {rendered}</span>
      </header>
      <nav class="dash" aria-label="Dashboard sections">
        <a href="/">Overview</a>
        <a href="/cost">Cost</a>
        <a href="/decisions">Decisions</a>
        <a href="/experiments">Experiments</a>
      </nav>

      {!env.ok && <ConfigBanner missing={env.missing} />}

      <h2>Free-tier quota headroom</h2>
      <QuotaBurnIndicator usage={[]} />

      <h2>Cost attribution</h2>
      <CostBreakdownTable lines={[]} />

      <p class="ops-note">
        Cost values are operator-fed at MVP. Source tags
        (<code>actual / estimate / placeholder</code>) keep precision
        honest. See
        <code>docs/cost-control-and-free-tier-plan.md</code> for the
        £0 MVP stack and £50/month ceiling, and
        <code>docs/profit-model.md</code> for the scenario
        boundaries.
      </p>
    </main>
  </body>
</html>
