---
import { envStatus, listDecisions, type DecisionRow } from '../lib/supabase.ts';
import ConfigBanner from '../components/ConfigBanner.astro';
import ErrorPanel from '../components/ErrorPanel.astro';
import EmptyState from '../components/EmptyState.astro';
import DecisionsTable from '../components/DecisionsTable.astro';

const env = envStatus();
let rows: DecisionRow[] = [];
let error: { status?: number; detail: string } | null = null;
if (env.ok) {
  const r = await listDecisions(30);
  if (r.ok) rows = r.data;
  else if (r.kind === 'fetch_error') error = { status: r.status, detail: r.detail };
}
const rendered = new Date().toISOString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>HamMediaLabs — Decisions</title>
    <style>
      :root { font: 15px/1.5 system-ui, -apple-system, Segoe UI, sans-serif; }
      body { margin: 0; color: #1c1c1c; background: #fff; }
      main { max-width: 980px; margin: 0 auto; padding: 1.5rem; }
      header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1rem; }
      h1 { margin: 0; font-size: 1.4rem; }
      h2 { margin: 1.5rem 0 0.5rem; font-size: 1.1rem; }
      .stamp { color: #6a6a6a; font-size: 0.82rem; font-variant-numeric: tabular-nums; }
      nav.dash { margin: 0.5rem 0 1rem; font-size: 0.9rem; }
      nav.dash a { color: #114488; text-decoration: none; margin-right: 0.8rem; }
      .ops-note { margin-top: 1.5rem; padding-top: 0.75rem; border-top: 1px solid #eee; color: #6a6a6a; font-size: 0.85rem; }
    </style>
  </head>
  <body>
    <main>
      <header>
        <h1>Decisions (last 30 days)</h1>
        <span class="stamp">rendered {rendered}</span>
      </header>
      <nav class="dash" aria-label="Dashboard sections">
        <a href="/">Overview</a>
        <a href="/cost">Cost</a>
        <a href="/decisions">Decisions</a>
        <a href="/experiments">Experiments</a>
      </nav>

      {!env.ok && <ConfigBanner missing={env.missing} />}
      {error && <ErrorPanel title="Couldn't load decisions" status={error.status} detail={error.detail} />}
      {env.ok && !error && rows.length === 0 && (
        <EmptyState
          message="No decisions in the last 30 days."
          hint="every weekly review and every paid-line approval lands here"
        />
      )}
      {rows.length > 0 && <DecisionsTable rows={rows} />}

      <p class="ops-note">
        Decisions sourced from the HQ <code>decision</code> table.
        Operator entries land here automatically via
        <code>docs/15-decision-log.md</code>'s parallel SQL inserts
        (when wired in a future PR; until then the dashboard reflects
        whatever is in the table).
      </p>
    </main>
  </body>
</html>
