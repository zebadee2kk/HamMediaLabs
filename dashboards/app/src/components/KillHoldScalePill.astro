---
import type { Verdict } from '../lib/scoring.ts';
interface Props { verdict: Verdict; }
const { verdict } = Astro.props;
const labels: Record<Verdict, string> = {
  kill: 'kill',
  hold: 'hold',
  scale_candidate: 'scale?',
  unknown: '—',
};
---
<span class={`khs ${verdict}`} aria-label={`Verdict: ${labels[verdict]}`}>{labels[verdict]}</span>

<style>
  .khs {
    display: inline-block;
    padding: 0.08rem 0.5rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-variant-numeric: tabular-nums;
  }
  .khs.kill            { background: #f7c5c0; color: #5f1d1d; }
  .khs.hold            { background: #fff1c2; color: #5f4a1d; }
  .khs.scale_candidate { background: #c5d9f7; color: #1d2d5f; }
  .khs.unknown         { background: #e6e6e6; color: #555; }
</style>
