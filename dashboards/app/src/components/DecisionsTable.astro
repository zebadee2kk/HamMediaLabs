---
import { shortDate } from '../lib/format.ts';
import type { DecisionRow } from '../lib/supabase.ts';

interface Props {
  rows: DecisionRow[];
}
const { rows } = Astro.props;
---
<table aria-label="Recent decisions">
  <thead>
    <tr>
      <th>Date</th>
      <th>Scope</th>
      <th>Kind</th>
      <th>Reason</th>
      <th>Operator</th>
      <th>Revisit</th>
    </tr>
  </thead>
  <tbody>
    {rows.map(d => (
      <tr>
        <td>{shortDate(d.ts)}</td>
        <td><span class={`scope ${d.scope}`}>{d.scope}</span></td>
        <td><span class={`kind ${d.kind}`}>{d.kind}</span></td>
        <td class="reason">{d.reason}</td>
        <td>{d.operator}</td>
        <td>{shortDate(d.revisit_date)}</td>
      </tr>
    ))}
  </tbody>
</table>

<style>
  table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; }
  th, td { text-align: left; padding: 0.45rem 0.6rem; border-bottom: 1px solid #eee; vertical-align: top; }
  th { background: #f6f6f6; font-weight: 600; }
  .scope, .kind {
    display: inline-block; padding: 0.05rem 0.5rem; border-radius: 999px; font-size: 0.75rem;
  }
  .scope.portfolio  { background: #c5d9f7; color: #1d2d5f; }
  .scope.brand      { background: #d2f5d6; color: #1d5f24; }
  .scope.provider   { background: #fff1c2; color: #5f4a1d; }
  .scope.compliance { background: #f7c5c0; color: #5f1d1d; }
  .scope.security   { background: #f7d4c0; color: #5f3a1d; }
  .kind.kill   { background: #f7c5c0; color: #5f1d1d; }
  .kind.hold   { background: #fff1c2; color: #5f4a1d; }
  .kind.scale  { background: #c5d9f7; color: #1d2d5f; }
  .kind.adopt  { background: #d2f5d6; color: #1d5f24; }
  .kind.retire { background: #e6e6e6; color: #555; }
  .kind.rotate { background: #f7d4c0; color: #5f3a1d; }
  .kind.other  { background: #e6e6e6; color: #555; }
  .reason { font-size: 0.92rem; }
</style>
