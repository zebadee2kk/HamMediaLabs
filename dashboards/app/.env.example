# Dashboard environment variables (template only — never commit live values).
# Copy to a local .env (gitignored at the repo root) or set in your shell.
#
# NEVER prefix these with PUBLIC_ — they are Tier 1 secrets and must stay
# server-side. See docs/09-security-and-secrets.md.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — used as the Astro `site` URL for absolute links.
DASHBOARD_URL=http://localhost:4321
